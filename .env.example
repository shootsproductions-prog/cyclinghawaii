# Strava API credentials
# Get these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
STRAVA_ATHLETE_ID=

# Encryption key for rider OAuth tokens stored in Vercel Blob.
# Generate a new one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RIDER_ENCRYPTION_KEY=

# Printful API access token. Get from
# https://www.printful.com/dashboard/store → Settings → API
# Read access is sufficient for product sync. Add write scope if you
# want automated fulfillment via Stripe webhooks.
PRINTFUL_API_TOKEN=

# Password gating /admin/* tools (Laura voice generator, etc.).
# Pick anything you'll remember.
ADMIN_PASSWORD=
